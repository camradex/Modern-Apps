{
  "manifest_version": 2,
  "name": "Content Blocker",
  "version": "1.0",
  "description": "Blocks ads, trackers, adult content, and gambling",
  "browser_specific_settings": {
    "gecko": {
      "id": "content-blocker@vayunmathur.com"
    }
  },
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["domains.js", "background.js"]
  }
}
